# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.

# JWT — generate with: openssl rand -hex 32
# Do NOT use any placeholder value in production.
SECRET_KEY=

# App environment
APP_ENV=production

# Local PostgreSQL
DATABASE_URL=postgresql://nutritrack:CHANGE_ME@localhost:5432/nutritrack
POSTGRES_PASSWORD=CHANGE_ME

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Cookie security. Production must keep this true behind HTTPS.
# Set COOKIE_SECURE=false only in a local development .env.
COOKIE_SECURE=true

# Public frontend URL used in password reset links
PUBLIC_APP_URL=https://your-domain.example

# SMTP settings for password reset email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@nutritrack.app
SMTP_USE_TLS=true

# Local Ollama (OpenAI-compatible API)
# Required for PDF extraction and meal parsing.
# When running via docker-compose, the backend container reaches the host at:
#   http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_MAX_RETRIES=2

# Local data directories
CHROMA_PERSIST_DIR=.local/chroma
UPLOAD_DIR=.local/uploads
