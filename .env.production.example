# Copy to .env on the production host before running docker compose.
APP_ENV=production
DEBUG=false
SECRET_KEY=
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://nutritrack:REPLACE_WITH_STRONG_PASSWORD@db:5432/nutritrack
CORS_ORIGINS=https://your-domain.example
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
PUBLIC_APP_URL=https://your-domain.example
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@your-domain.example
SMTP_USE_TLS=true
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_MAX_RETRIES=2
RATE_LIMIT_STORAGE_URI=redis://redis:6379/0
TRUSTED_PROXY_CIDRS=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16,127.0.0.1/32,::1/128
MAX_UPLOAD_BYTES=10485760
PDF_MAX_PAGES=6
PDF_OCR_MAX_PAGES=2
PDF_EXTRACTION_TIMEOUT_SECONDS=20
PDF_MAX_PAGE_DIMENSION_POINTS=2880
PDF_MAX_RENDER_PIXELS=8000000
PDF_OCR_SCALE=1.5
CHROMA_PERSIST_DIR=/data/chroma
UPLOAD_DIR=/data/uploads
